rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jently.f.tamailang@gmail.com' &&
        request.auth.token.email_verified == true
      );
    }

    // --- Validation Helpers ---
    function isValidAuthorizedUser(data) {
      return data.keys().hasAll(['addedAt', 'addedBy']) &&
             data.keys().size() == 2 &&
             data.addedAt is string &&
             data.addedBy == request.auth.token.email &&
             data.addedBy is string;
    }

    function isValidSavedPerangkat(data) {
      return data.keys().hasAll(['userId', 'title', 'payload', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 1000 &&
             data.payload is string && data.payload.size() <= 1000000 &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    // --- Collections ---
    match /authorized_users/{email} {
      // Allow get for everyone signed in (to check their own access)
      // and administrators to list/read all.
      allow get: if isSignedIn() && (request.auth.token.email == email || isAdmin());
      allow list: if isAdmin();

      // Only admins can add or remove authorized users.
      allow create: if isAdmin() && isValidAuthorizedUser(incoming());
      allow update: if false; // No updates allowed for this simple collection
      allow delete: if isAdmin();
    }

    match /perangkat_ajar/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(docId) && 
                    isValidSavedPerangkat(incoming()) && 
                    (isAdmin() || exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)));

      allow update: if isSignedIn() && 
                    isValidId(docId) && 
                    existing().userId == request.auth.uid &&
                    isValidSavedPerangkat(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'payload', 'updatedAt']);

      allow delete: if isSignedIn() && isValidId(docId) && existing().userId == request.auth.uid;
    }
  }
}
